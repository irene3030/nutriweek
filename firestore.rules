rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // FF activation counter — any auth user can read; can only increment up to 10
    match /meta/ffActivation {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.count == 1;
      allow update: if request.auth != null
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= 10;
    }

    match /households/{householdId} {
      // Any authenticated user can read households (needed to query by inviteCode)
      allow read: if request.auth != null;

      // Allow creating a household if the creator is in the members array
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;

      // Allow update if: already a member OR joining (adding own uid to members)
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId ||
        request.auth.uid in request.resource.data.members
      );

      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId;

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId;
      }
    }
  }
}

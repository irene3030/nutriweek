rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /households/{householdId} {
      // Allow creating a household if the authenticated user is in the members array
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;

      // Allow read/write if the user already belongs to this household
      allow read, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId;

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId;
      }
    }

    // Allow querying households by inviteCode (for joining)
    match /households/{householdId} {
      allow read: if request.auth != null;
    }
  }
}
